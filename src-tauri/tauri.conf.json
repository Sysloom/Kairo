{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kairo",
  "version": "0.1.1",
  "identifier": "dev.focus-tray.app",
  "build": {
    "beforeDevCommand": "npx pnpm@10.11.0 dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx pnpm@10.11.0 build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kairo",
        "width": 456,
        "height": 676,
        "minWidth": 420,
        "minHeight": 636,
        "resizable": true,
        "visible": true
      },
      {
        "label": "timer",
        "title": "Kairo",
        "width": 292,
        "height": 242,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false
      },
      {
        "label": "mini-timer",
        "title": "Kairo Mini Timer",
        "width": 80,
        "height": 32,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.png"
    ]
  }
}
